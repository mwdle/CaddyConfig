{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>lab/renovate-config"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["**/Dockerfile"],
      "matchStrings": [
        "xcaddy build\\s+--with\\s+(?<depName>[^\\s@]+)@(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "go"
    }
  ]
}
